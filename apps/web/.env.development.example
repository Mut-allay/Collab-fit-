# Copy to .env.development.local (recommended) or merge into .env
# Vite loads: .env, .env.local, .env.[mode], .env.[mode].local
# See docs/LOCAL_DEV.md

# --- Option A: Local UI + deployed API (typical) ---
# VITE_API_URL=https://your-api.onrender.com

# --- Option B: Local UI + local API (pnpm dev:api, port 3000) ---
VITE_API_URL=http://localhost:3000

# Firebase web SDK (public keys only — from Firebase Console → Project settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional
# VITE_FIREBASE_MEASUREMENT_ID=
