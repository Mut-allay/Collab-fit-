# Copy to api/.env — never commit api/.env
# Loaded by api/server.js via dotenv

# --- Server ---
PORT=3000
# Primary site + optional local Vite (comma-separated). Used for CORS and OAuth return.
# Example: https://your-app.web.app,http://localhost:5173
FRONTEND_URL=http://localhost:5173

# --- Firebase Admin (pick ONE style) ---
# Single-line JSON (escape quotes as needed):
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# OR discrete fields:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Google OAuth (Fitness + login consent) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an "Authorized redirect URI" in Google Cloud Console:
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# --- Cron / bulk jobs only (Authorization: Bearer <this value>) ---
API_SECRET_KEY=
